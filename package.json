{
  "name": "alert-whatif",
  "version": "0.1.0",
  "private": true,
  "description": "Tune Grafana alert parameters and see the what-if result on real historical data — before shipping.",
  "license": "MIT",
  "author": "Alertcraft",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.30.3",
  "pnpm": {
    "overrides": {
      "immutable": "5.1.5",
      "js-cookie": "3.0.7",
      "serialize-javascript": "7.0.5"
    }
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r exec rm -rf node_modules dist"
  },
  "devDependencies": {
    "@types/node": "^22.0.0"
  }
}
