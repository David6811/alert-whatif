# OPTIONAL — you do NOT need this to run the plugin. `docker compose up` works
# out of the box against a self-contained local Prometheus (the default
# datasource) with a provisioned sample alert rule.
#
# Set these two only if you also want a Grafana Cloud Prometheus datasource
# (provisioning/datasources/grafanacloud-prom.yaml, non-default). Copy this
# file to `.env` (gitignored); both vars are injected at runtime, so neither
# your Cloud URL nor the token lives in the repo.
#
# GC_PROM_URL — your Grafana Cloud datasource proxy URL. Proxying through the
# datasource means we only need a Bearer token, not the numeric Prom instance
# ID. Shape: https://<your-org>.grafana.net/api/datasources/proxy/uid/grafanacloud-prom
#
# GC_PROM_TOKEN — Grafana Cloud → My Account → Access Policies → New policy
# with scope `metrics:read`. Shape: `glsa_...`.

GC_PROM_URL=https://YOUR-ORG.grafana.net/api/datasources/proxy/uid/grafanacloud-prom
GC_PROM_TOKEN=glsa_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
