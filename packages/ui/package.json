{
  "name": "@alert-whatif/ui",
  "version": "0.1.0",
  "description": "Shared React components for alert-whatif (chart, compute trace, parameter controls). Pure presentational layer — no Grafana SDK, no datasource concerns. Consumed by @alert-whatif/demo and @alert-whatif/plugin.",
  "license": "MIT",
  "author": "Alertcraft",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/David6811/alert-whatif.git",
    "directory": "packages/ui"
  },
  "homepage": "https://github.com/David6811/alert-whatif#readme",
  "bugs": "https://github.com/David6811/alert-whatif/issues",
  "keywords": [
    "grafana",
    "alerting",
    "alert-rules",
    "react",
    "visualization"
  ],
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "pnpm run build"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "dependencies": {
    "@alert-whatif/core": "workspace:^",
    "@emotion/css": "11.10.6"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.7.0",
    "happy-dom": "^20.9.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.0",
    "vitest": "^3.2.4"
  }
}
